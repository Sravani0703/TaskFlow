{
  "name": "taskflow",
  "version": "1.0.0",
  "description": "Task Management API with JWT authentication and RBAC",
  "main": "src/index.js",
  "scripts": {
    "start": "node src/index.js",
    "dev": "nodemon src/index.js",
    "seed": "node scripts/seedDatabase.js",
    "test": "jest --detectOpenHandles",
    "test:watch": "jest --watch",
    "lint": "eslint src/",
    "migrate": "sequelize db:migrate",
    "migrate:undo": "sequelize db:migrate:undo:all"
  },
  "keywords": [
    "task-management",
    "api",
    "express",
    "jwt",
    "rbac",
    "mysql"
  ],
  "author": "Sravani0703",
  "license": "MIT",
  "dependencies": {
    "express": "^4.18.2",
    "sequelize": "^6.35.2",
    "mysql2": "^3.6.5",
    "jsonwebtoken": "^9.1.2",
    "bcryptjs": "^2.4.3",
    "dotenv": "^16.3.1",
    "joi": "^17.11.0",
    "node-cron": "^3.0.3",
    "nodemailer": "^6.9.7",
    "cors": "^2.8.5",
    "helmet": "^7.1.0",
    "express-rate-limit": "^7.1.5"
  },
  "devDependencies": {
    "nodemon": "^3.0.2",
    "jest": "^29.7.0",
    "supertest": "^6.3.3",
    "eslint": "^8.54.0",
    "sequelize-cli": "^6.6.2"
  }
}
